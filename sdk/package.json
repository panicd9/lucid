{
  "name": "@lucid/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/kit": "^2.0.0",
    "@solana/web3.js": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=v20.0.0"
  }
}
